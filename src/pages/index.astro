---
import Layout from "@/layouts/Layout.astro";
import MatchdayLayout from "@/layouts/MatchdayLayout.astro";
import LiveMatchHero from "@/components/organisms/LiveMatchHero.astro";
import NextMatchesCarousel from "@/components/organisms/NextMatchesCarousel.astro";
import RecentResultsList from "@/components/organisms/RecentResultsList.astro";
import type { IconName } from "@/lib/types";
import { getScoreboard, getScoreboardRange, ApiError } from "@/lib/espn/client";
import {
  mapToHeroEvent,
  mapToMatchEvents,
  mapToMatch,
  mapToResult,
  isEventLive,
  isEventPre,
  isEventPost,
} from "@/lib/espn/mappers";

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}${m}${d}`;
}

let heroData: {
  homeTeam: { src: string; name: string };
  awayTeam: { src: string; name: string };
  homeScore: number;
  awayScore: number;
  liveTime: string;
} | null = null;
let heroEvents: Array<{
  icon: IconName;
  text: string;
  iconClass?: string;
  muted?: boolean;
}> = [];
let isLive = false;
let heroError: { status: number } | null = null;
let preMatches: Array<{ date: string; homeTeam: { src: string; name: string }; awayTeam: { src: string; name: string } }> = [];
let postResults: Array<{
  date: string;
  homeTeam: { src: string; name: string };
  awayTeam: { src: string; name: string };
  homeScore: number;
  awayScore: number;
  performances: Array<{ label: string; homeValue: string; awayValue: string; homePercent: number }>;
  stats: Array<{ icon: IconName; label: string; value1: number; value2: number; iconClass?: string }>;
}> = [];

// Past week results: one date-range call for completed matches
const today = new Date();
const pastStart = new Date(today);
pastStart.setDate(pastStart.getDate() - 7);
try {
  const pastData = await getScoreboardRange(formatDate(pastStart), formatDate(today));
  const pastPosts = pastData.events.filter(isEventPost);
  if (pastPosts.length > 0) {
    postResults = pastPosts.map(mapToResult).reverse();
  }
} catch {
  // silencio — postResults queda vacío, no se muestra la sección
}

for (let offset = 0; offset < 7; offset++) {
  const date = new Date();
  date.setDate(date.getDate() + offset);
  const ds = formatDate(date);

  try {
    const data = await getScoreboard(ds);

    if (data.events.length === 0) continue;

    // Hero: take first live or pre event we find across days
    if (!heroData) {
      const liveEvent = data.events.find(isEventLive);
      const targetEvent = liveEvent ?? data.events.find(isEventPre) ?? null;

      if (targetEvent) {
        const mapped = mapToHeroEvent(targetEvent);
        heroData = {
          homeTeam: mapped.homeTeam,
          awayTeam: mapped.awayTeam,
          homeScore: mapped.homeScore,
          awayScore: mapped.awayScore,
          liveTime: mapped.liveTime,
        };
        heroEvents = mapToMatchEvents(targetEvent);
        isLive = mapped.isLive;
      }
    }

    // Carousel: collect pre events from all days until we have enough
    const dayPre = data.events.filter(isEventPre);
    const remaining = 10 - preMatches.length;

    if (dayPre.length > 0) {
      preMatches.push(...dayPre.slice(0, remaining).map(mapToMatch));
    }

    if (preMatches.length >= 10) break;
  } catch (e) {
    if (offset === 6 && !heroData) {
      heroError = e instanceof ApiError ? { status: e.status } : { status: 0 };
    }
  }
}
---

<Layout>
  <MatchdayLayout>
    {
      heroError ? (
        <section class="max-w-lg mx-auto">
          <div class="rounded-xl bg-card border p-6 text-center space-y-2">
            <p class="text-muted-foreground text-sm">
              No pudimos cargar los datos en vivo.
            </p>
            <p class="text-destructive text-xs font-mono">
              {heroError.status > 0 ? `Error ${heroError.status}` : "Error de conexión"}
            </p>
          </div>
        </section>
      ) : heroData ? (
        <LiveMatchHero
          homeTeam={heroData.homeTeam}
          awayTeam={heroData.awayTeam}
          homeScore={heroData.homeScore}
          awayScore={heroData.awayScore}
          liveTime={isLive ? heroData.liveTime : undefined}
          events={heroEvents}
        />
      ) : null
    }
    {
      preMatches.length > 0 && (
        <NextMatchesCarousel matches={preMatches} />
      )
    }
    {
      postResults.length > 0 && (
        <RecentResultsList results={postResults} />
      )
    }
  </MatchdayLayout>
</Layout>
