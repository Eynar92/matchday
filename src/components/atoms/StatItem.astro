---
import type { IconName } from "@/lib/types";
import LucideIcon from "@/components/atoms/LucideIcon";

export interface Props {
  icon: IconName;
  value1: number;
  value2: number;
  iconClass?: string;
  class?: string;
}

const { icon, value1, value2, iconClass = "text-muted-foreground", class: className = "" } = Astro.props;
---

<div class={`flex flex-col items-center gap-1 ${className}`}>
  <LucideIcon name={icon} size={16} className={iconClass} />
  <span class="text-xs font-medium text-muted-foreground">{value1} | {value2}</span>
</div>
