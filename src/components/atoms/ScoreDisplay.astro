---
type ScoreSize = 'sm' | 'md' | 'lg'

const sizeMap: Record<ScoreSize, { score: string; colon: string }> = {
  sm: { score: 'text-2xl md:text-3xl', colon: 'text-lg md:text-xl' },
  md: { score: 'text-4xl md:text-5xl', colon: 'text-xl md:text-2xl' },
  lg: { score: 'text-5xl md:text-6xl', colon: 'text-2xl md:text-3xl' },
}

export interface Props {
  homeScore: number
  awayScore: number
  size?: ScoreSize
  class?: string
}

const { homeScore, awayScore, size = 'lg', class: className = '' } = Astro.props
const s = sizeMap[size]
---

<div class={`flex items-center gap-2 ${className}`}>
  <span class={`${s.score} font-extrabold tracking-tighter leading-none`}>{homeScore}</span>
  <span class={`${s.colon} text-muted-foreground/30 font-semibold leading-none`}>:</span>
  <span class={`${s.score} font-extrabold tracking-tighter leading-none`}>{awayScore}</span>
</div>
