---
import type { BarColor } from "@/lib/types";

export interface Props {
  label: string
  homeValue: string
  awayValue: string
  homePercent: number
  homeColor?: BarColor
  awayColor?: BarColor
  class?: string
}

const {
  label,
  homeValue,
  awayValue,
  homePercent,
  homeColor = 'bg-green-500',
  awayColor = 'bg-blue-500',
  class: className = ''
} = Astro.props
---

<div class={`space-y-1 ${className}`}>
  <div class="flex justify-between text-[10px] font-bold uppercase text-muted-foreground tracking-widest px-1">
    <span>{label}</span>
    <span>{homeValue} - {awayValue}</span>
  </div>
  <div class="flex h-1.5 w-full bg-card rounded-full overflow-hidden">
    <div class={`h-full ${homeColor}`} style={`width: ${homePercent}%`}></div>
    <div class="bg-transparent h-full w-0.5"></div>
    <div class={`h-full flex-1 ${awayColor}`}></div>
  </div>
</div>
