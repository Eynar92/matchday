---
import MatchTeam from "@/components/molecules/MatchTeam.astro";
import ScoreDisplay from "@/components/atoms/ScoreDisplay.astro";
import MatchEvent from "@/components/atoms/MatchEvent.astro";
import type { ComponentProps } from "react";
import type LucideIcon from "@/components/atoms/LucideIcon";

type IconName = ComponentProps<typeof LucideIcon>["name"];

type Team = {
  src: string;
  name: string;
};

type Event = {
  icon: IconName;
  text: string;
  iconClass?: string;
  muted?: boolean;
};

export interface Props {
  homeTeam: Team;
  awayTeam: Team;
  homeScore: number;
  awayScore: number;
  liveTime?: string;
  events?: Event[];
  class?: string;
}

const {
  homeTeam,
  awayTeam,
  homeScore,
  awayScore,
  liveTime = "48:38",
  events = [
    { icon: "Soccer", text: "22' Saka" },
    { icon: "Square", text: "41' Rodri", iconClass: "text-yellow-500", muted: true },
  ],
  class: className = "",
} = Astro.props;
---

<section class={className}>
  <div class="relative overflow-hidden rounded-xl bg-card border p-6">
    <div class="absolute -top-12 -right-12 w-48 h-48 bg-destructive/10 rounded-full blur-[60px]"></div>
    <div class="relative z-10 flex flex-col items-center">
      <div class="flex items-center gap-2 mb-6">
        <div class="relative flex items-center justify-center w-3 h-3">
          <span class="absolute inline-flex h-full w-full rounded-full bg-destructive animate-ping opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-destructive"></span>
        </div>
        <span class="text-destructive text-xs font-bold uppercase tracking-widest">Live • {liveTime}</span>
      </div>
      <div class="w-full flex justify-between items-center mb-6">
        <MatchTeam src={homeTeam.src} name={homeTeam.name} size={64} />
        <ScoreDisplay homeScore={homeScore} awayScore={awayScore} size="lg" />
        <MatchTeam src={awayTeam.src} name={awayTeam.name} size={64} />
      </div>
      <div class="flex gap-4 items-center justify-center bg-muted/30 py-2 px-4 rounded-full">
        {
          events.map((event, i) => (
            <>
              {i > 0 && <div class="w-px h-3 bg-border"></div>}
              <MatchEvent icon={event.icon} text={event.text} iconClass={event.iconClass} muted={event.muted} />
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>
