---
import LucideIcon from "@/components/atoms/LucideIcon";
import type { ComponentProps } from "react";

type IconName = ComponentProps<typeof LucideIcon>["name"];

export interface Props {
  title?: string
  actions?: { icon: IconName; label?: string }[]
  class?: string
}

const {
  title = "MATCHDAY",
  actions = [{ icon: "Search" }, { icon: "CircleUser" }],
  class: className = ""
} = Astro.props
---

<header class={`fixed top-0 w-full z-50 bg-card/80 backdrop-blur-md border-b border-border flex items-center justify-between px-4 h-16 ${className}`}>
  <div class="flex items-center gap-4">
    <button class="hover:opacity-80 transition-opacity active:scale-95 duration-150 text-foreground">
      <LucideIcon name="Menu" size={24} />
    </button>
    <h1 class="text-xl md:text-2xl font-black tracking-tighter text-foreground">{title}</h1>
  </div>
  <div class="flex items-center gap-4">
    {
      actions.map((action) => (
        <button class="hover:opacity-80 transition-opacity active:scale-95 duration-150 text-foreground" aria-label={action.label ?? action.icon}>
          <LucideIcon name={action.icon} size={24} />
        </button>
      ))
    }
  </div>
</header>
