---
import { Button } from "@/components/ui/button";
import TeamLogo from "@/components/atoms/TeamLogo.astro";
import LucideIcon from "@/components/atoms/LucideIcon";

type Team = {
  src: string;
  name: string;
};

export interface Props {
  date: string;
  homeTeam: Team;
  awayTeam: Team;
  class?: string;
}

const { date, homeTeam, awayTeam, class: className = "" } = Astro.props;
---

<div class={`min-w-70 bg-card rounded-xl p-4 border flex flex-col gap-4 ${className}`}>
  <div class="flex justify-between items-center">
    <span class="text-xs font-medium text-muted-foreground">{date}</span>
  </div>
  <div class="flex justify-between items-center gap-4">
    <div class="flex flex-col items-center gap-2 flex-1">
      <TeamLogo src={homeTeam.src} alt={`${homeTeam.name} logo`} size={40} />
      <span class="text-xs font-bold text-center text-foreground">{homeTeam.name}</span>
    </div>
    <span class="text-muted-foreground text-xs font-bold">VS</span>
    <div class="flex flex-col items-center gap-2 flex-1">
      <TeamLogo src={awayTeam.src} alt={`${awayTeam.name} logo`} size={40} />
      <span class="text-xs font-bold text-center text-foreground">{awayTeam.name}</span>
    </div>
  </div>
  <Button variant="secondary" size="lg" className="w-full text-xs font-bold">
    Teams Details
  </Button>
</div>
